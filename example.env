# Required APIs
NUMVERIFY_KEY=your_numverify_api_key_here
SERPAPI_KEY=your_serpapi_key_here
GITHUB_TOKEN=your_github_token_here

# Optional: Proxy for OPSEC (routes ALL requests through it to hide your real IP)
# HTTP:        http://user:pass@host:port
# SOCKS5/Tor:  socks5h://127.0.0.1:9050   (use socks5h so DNS resolves via the proxy)
# The --proxy CLI flag overrides this value.
PROXY_URL=
